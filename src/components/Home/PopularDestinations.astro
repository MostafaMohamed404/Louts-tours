<section class="py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl font-semibold text-gray-900">
        Popular Destinations
      </h2>
      <p class="mt-3 text-gray-500 text-lg">
        Explore Our Top Travel Locations
      </p>
    </div>

    <!-- Slider -->
    <div class="relative">

      <!-- arrows -->
      <button id="prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-white shadow-md w-10 h-10 rounded-full">
        ←
      </button>

      <button id="next"
        class="absolute right-0 top-1/2 -translate-y-1/2 z-10 bg-white shadow-md w-10 h-10 rounded-full">
        →
      </button>

      <!-- cards -->
      <div id="slider"
        class="flex gap-6 overflow-x-auto scroll-smooth no-scrollbar">

        <!-- card -->
        <div class="min-w-[260px] h-[340px] rounded-2xl overflow-hidden relative group">
          <img src="/images/sharm-el-sheikh.webp"
            class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute bottom-5 left-5 text-white">
            <h4 class="text-lg font-semibold">Sharm El Sheikh</h4>
          </div>
        </div>

        <div class="min-w-[260px] h-[340px] rounded-2xl overflow-hidden relative group">
          <img src="/images/hurghada.webp"
            class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute bottom-5 left-5 text-white">
            <h4 class="text-lg font-semibold">Hurghada</h4>
          </div>
        </div>

        <div class="min-w-[260px] h-[340px] rounded-2xl overflow-hidden relative group">
          <img src="/images/marsa-alam.webp"
            class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute bottom-5 left-5 text-white">
            <h4 class="text-lg font-semibold">Marsa Alam</h4>
          </div>
        </div>

        <div class="min-w-[260px] h-[340px] rounded-2xl overflow-hidden relative group">
          <img src="/images/dubai.webp"
            class="w-full h-full object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute bottom-5 left-5 text-white">
            <h4 class="text-lg font-semibold">Dubai</h4>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<script is:inline>
  const slider = document.getElementById("slider");
  const next = document.getElementById("next");
  const prev = document.getElementById("prev");

  next.onclick = () => {
    slider.scrollBy({ left: 300, behavior: "smooth" });
  };

  prev.onclick = () => {
    slider.scrollBy({ left: -300, behavior: "smooth" });
  };
</script>